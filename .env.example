# Copie ce fichier en .env et remplis tes clés Supabase
# Supabase Dashboard → Settings → API

SUPABASE_URL=https://XXXXXXXXXXXX.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Spotify — developer.spotify.com → Create app → Client ID + Client Secret
# Nécessaire pour importer des playlists Spotify et rechercher des titres
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

PORT=3000
